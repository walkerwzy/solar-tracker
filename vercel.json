{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "builds": [
    {
      "src": "api/**/*.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/api/main.py"
    }
  ],
  "functions": {
    "api/**/*.py": {
      "excludeFiles": "{screen.png,.git/**,README*,LICENSE,AGENTS.md,DESIGN.md,.venv/**}"
    }
  }
}